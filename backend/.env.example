# Atlas backend — environment variables template
# Copie este arquivo pra .env.development (gitignored) e ajuste pro seu setup local.

# === Database ===
# SQLite (default, dev rápido):
DATABASE_URL=sqlite:///./dynamic_template.db
# Postgres local (M3 Fase 0.2):
# DATABASE_URL=postgresql+psycopg2://postgres:devpass@localhost:5432/dynamic_cms
# Postgres de teste (M3 Fase 7):
# DATABASE_URL_TEST=postgresql+psycopg2://postgres:devpass@localhost:5432/dynamic_cms_test

# === Auth ===
SECRET_KEY=dev-only-change-me-in-prod

# === Test seed ===
# Setado pelo conftest.py automaticamente; ajuste só se for rodar testes manuais.
# SKIP_TEST_SEED=1
